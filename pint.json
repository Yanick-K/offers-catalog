{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_unused_imports": true,
        "concat_space": {
            "spacing": "one"
        },
        "binary_operator_spaces": {
            "default": "single_space"
        },
        "class_attributes_separation": {
            "elements": {
                "method": "one",
                "property": "one"
            }
        },
        "single_quote": true,
        "trailing_comma_in_multiline": true,
        "no_superfluous_phpdoc_tags": true,
        "phpdoc_align": true,
        "phpdoc_order": true
    }
}
